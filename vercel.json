{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/(app.css|app.js)",
      "dest": "app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app/static/index.html"
    }
  ]
}
