# Server configuration
HOST=127.0.0.1
PORT=8000

# API Security
# In a real environment, we'd use a strong secret.
API_SECRET_KEY=fifa_world_cup_2026_operations_secret_key
RATE_LIMIT_PER_MINUTE=20

# GenAI Configuration
# Set to 'true' to use the local mock fallback model for offline/evaluation usage.
# Set to 'false' to use the live Gemini API (GEMINI_API_KEY required).
USE_MOCK_LLM=true
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Egress parameters
STADIUM_NAME=MetLife Stadium
STADIUM_CAPACITY=82500
